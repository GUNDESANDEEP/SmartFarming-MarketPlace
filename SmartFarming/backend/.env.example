# Smart Farm Marketplace - Backend Environment Template

# Copy this file to .env and fill in your values

# =============================================
# Flask Configuration
# =============================================
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# =============================================
# Database Configuration
# =============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=SmartFarmingDB

# =============================================
# JWT Configuration
# =============================================
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=86400

# =============================================
# Email Configuration (SMTP)
# =============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# =============================================
# SMS Configuration (Twilio)
# =============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================
# Payment Gateway (Razorpay)
# =============================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# =============================================
# Weather API
# =============================================
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/3.0/stations

# =============================================
# AI/ML Configuration
# =============================================
CROP_RECOMMENDATION_MODEL_PATH=models/crop_recommendation.pkl
PRICE_FORECAST_MODEL_PATH=models/price_forecast.pkl
AI_MODEL_UPDATE_FREQUENCY=weekly

# =============================================
# AWS Configuration (for S3 uploads)
# =============================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=smartfarm-uploads
AWS_REGION=ap-south-1
AWS_S3_UPLOAD_FOLDER=products

# =============================================
# Redis Configuration (for caching & sessions)
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TYPE=redis

# =============================================
# Logging Configuration
# =============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# =============================================
# Application Settings
# =============================================
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf
PRODUCTS_PER_PAGE=20
ORDERS_PER_PAGE=10

# =============================================
# Security Settings
# =============================================
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================
# Stripe Configuration (Alternative Payment Gateway)
# =============================================
STRIPE_API_KEY=your-stripe-api-key
STRIPE_PUBLIC_KEY=your-stripe-public-key

# =============================================
# SendGrid Configuration (Alternative Email)
# =============================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@smartfarm.com

# =============================================
# Analytics Configuration
# =============================================
GOOGLE_ANALYTICS_ID=your-google-analytics-id
MIXPANEL_TOKEN=your-mixpanel-token

# =============================================
# Environment Type
# =============================================
# Values: development, staging, production
ENVIRONMENT=development

# =============================================
# Debug Mode
# =============================================
DEBUG=True
TESTING=False
