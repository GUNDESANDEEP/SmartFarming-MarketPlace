# ===================================================================
# SMART FARMING - ENVIRONMENT CONFIGURATION
# ===================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control
# ===================================================================

# ===================================================================
# 1. JWT AUTHENTICATION - Token Management
# ===================================================================
# JWT Secret Key for signing tokens (generate a strong random key)
# Used for: Admin login, Buyer login, Farmer login, API authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-32-chars-min
JWT_ACCESS_TOKEN_EXPIRES=86400

# ===================================================================
# 2. DATABASE CONFIGURATION - MySQL Connection
# ===================================================================
# Database host (localhost for development, IP/hostname for production)
DB_HOST=localhost
# Database user (root for development, limited user for production)
DB_USER=root
# Database password (empty for development, strong password for production)
DB_PASSWORD=
# Database name
DB_NAME=smart_farming_db

# ===================================================================
# 3. EMAIL CONFIGURATION - SMTP Settings
# ===================================================================
# SMTP Server (Gmail: smtp.gmail.com, SendGrid: smtp.sendgrid.net)
SMTP_SERVER=smtp.gmail.com
# SMTP Port (Gmail: 587, SendGrid: 587)
SMTP_PORT=587
# Sender email address (used for sending notifications)
EMAIL_SENDER=noreply@smartfarming.com
# Email password or app-specific password
# For Gmail: Use app password (2FA enabled) not regular password
# For SendGrid: Use API key
EMAIL_PASSWORD=your-email-password-or-app-key

# ===================================================================
# 4. PAYMENT GATEWAY - Razorpay
# ===================================================================
# Razorpay API Key ID (from dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
# Razorpay API Key Secret (from dashboard)
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxx
# Razorpay Webhook Secret (for validating webhook signatures)
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxx

# ===================================================================
# 5. SMS GATEWAY - Twilio
# ===================================================================
# Twilio Account SID (from dashboard)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio Auth Token (from dashboard)
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Twilio Phone Number (your Twilio number for sending SMS)
TWILIO_PHONE_NUMBER=+1234567890
# Twilio API Key SID (for programmatic access)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio API Key Secret
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxx

# ===================================================================
# 6. AWS SERVICES
# ===================================================================
# AWS Access Key ID (for S3, SES, SNS)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS Region (e.g., us-east-1, ap-south-1)
AWS_REGION=ap-south-1
# AWS S3 Bucket (for storing product images, documents)
AWS_S3_BUCKET=smart-farming-bucket
# AWS SES Sender Email (if using AWS for email instead of SMTP)
AWS_SES_SENDER=noreply@smartfarming.com

# ===================================================================
# 7. WEATHER API - OpenWeatherMap
# ===================================================================
# OpenWeatherMap API Key (from openweathermap.org)
WEATHER_API_KEY=your-openweathermap-api-key
# Weather API Base URL
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ===================================================================
# 8. STRIPE PAYMENT (Alternative to Razorpay)
# ===================================================================
# Stripe Publishable Key (public, safe to expose)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
# Stripe Secret Key (keep secret!)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
# Stripe Webhook Secret (for validating webhook signatures)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ===================================================================
# 9. SENDGRID EMAIL (Alternative to Gmail SMTP)
# ===================================================================
# SendGrid API Key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SendGrid Sender Email
SENDGRID_FROM_EMAIL=noreply@smartfarming.com

# ===================================================================
# 10. REDIS CACHE - Session & Task Queue
# ===================================================================
# Redis Host (localhost for development)
REDIS_HOST=localhost
# Redis Port (6379 is default)
REDIS_PORT=6379
# Redis Password (if required)
REDIS_PASSWORD=
# Redis Database (0 for sessions, 1 for celery tasks)
REDIS_DB=0

# ===================================================================
# 11. ADMIN SUPER USER - Initial Setup
# ===================================================================
# Super Admin Email (for first admin account)
SUPER_ADMIN_EMAIL=admin@smartfarming.
# Super Admin Password (CHANGE THIS IMMEDIATELY IN PRODUCTION)
SUPER_ADMIN_PASSWORD=Change@123#Secure
# Super Admin Phone
SUPER_ADMIN_PHONE=9876543210

# ===================================================================
# 12. APPLICATION SETTINGS
# ===================================================================
# Environment (development, staging, production)
ENVIRONMENT=development
# Flask Debug Mode (True for development, False for production)
DEBUG=True
# Host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost)
HOST=0.0.0.0
# Port (5000 for development, 8000 for production with Gunicorn)
PORT=5000
# CORS Origins (comma-separated, * for all in development)
CORS_ORIGINS=*

# ===================================================================
# 13. LOGGING & MONITORING
# ===================================================================
# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Log File Path
LOG_FILE_PATH=logs/app.log
# Sentry DSN (for error tracking in production)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ===================================================================
# 14. ANALYTICS & TRACKING
# ===================================================================
# Google Analytics Tracking ID
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# Mixpanel Project Token
MIXPANEL_TOKEN=xxxxxxxxxxxxx

# ===================================================================
# 15. SECURITY SETTINGS
# ===================================================================
# Password Hash Salt Rounds (10-12 recommended)
BCRYPT_ROUNDS=10
# Session Timeout (in minutes)
SESSION_TIMEOUT=30
# Max Login Attempts
MAX_LOGIN_ATTEMPTS=5
# Lock Duration (in minutes)
LOCK_DURATION=15

# ===================================================================
# 16. FILE UPLOAD SETTINGS
# ===================================================================
# Max Upload File Size (in MB)
MAX_UPLOAD_SIZE=10
# Allowed File Extensions (comma-separated)
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx
# Upload Directory Path
UPLOAD_DIR=uploads

# ===================================================================
# 17. WEBHOOK CONFIGURATION
# ===================================================================
# Webhook Secret Key (for validating webhook requests)
WEBHOOK_SECRET=your-webhook-secret-key
# Webhook Retry Attempts
WEBHOOK_RETRY_ATTEMPTS=3
# Webhook Retry Delay (in seconds)
WEBHOOK_RETRY_DELAY=60

# ===================================================================
# AUTHENTICATION TYPES USED IN THIS PROJECT:
# ===================================================================
#
# 1. JWT (JSON Web Token) Authentication
#    - Used for: API endpoint authentication after login
#    - Key: JWT_SECRET_KEY
#    - Duration: 24 hours
#    - Contains: user_id, type (farmer/buyer/admin), email, role
#
# 2. OTP (One Time Password) Verification
#    - Used for: Buyer signup/login, Farmer signup/login
#    - Delivery: SMS via Twilio
#    - Expiry: 10 minutes
#    - Max attempts: 3
#
# 3. Email/Password Authentication (Admin)
#    - Used for: Admin panel login
#    - Password hashing: Bcrypt (10 rounds)
#    - Key: JWT_SECRET_KEY for token generation
#
# 4. Phone-based Authentication (Farmer & Buyer)
#    - Used for: Initial account creation
#    - Verification: OTP via SMS (Twilio)
#
# 5. API Key Authentication (Optional for external services)
#    - Used for: Third-party integrations
#    - Example: Weather API, Payment gateway webhooks
#
# ===================================================================
